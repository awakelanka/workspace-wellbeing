{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@workspace-wellbeing/auth": ["packages/auth/src/index.ts"],
      "@workspace-wellbeing/api-client": ["packages/api-client/src/index.ts"],
      "@workspace-wellbeing/modules": ["packages/modules/src/index.ts"],
      "@workspace-wellbeing/platform": ["packages/platform/src/index.ts"],
      "@workspace-wellbeing/tailwind-config": [
        "packages/tailwind-config/src/index.ts"
      ],
      "@workspace-wellbeing/ui": ["packages/ui/src/index.ts"]
    }
  }
}
